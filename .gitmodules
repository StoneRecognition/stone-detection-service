# =============================================================================
# Prioritized Modules (Active)
# =============================================================================

# GroundingDINO - Text-guided object detection
[submodule "GroundingDINO"]
	path = GroundingDINO
	url = https://github.com/IDEA-Research/GroundingDINO.git
	branch = main

# Recognize Anything - Contains: RAM, RAM+, TAG2TEXT
[submodule "recognize-anything"]
	path = recognize-anything
	url = https://github.com/xinyu1205/recognize-anything.git
	branch = main

# SAM-HQ - High Quality variant of Segment Anything Model (SAM)
[submodule "sam-hq"]
	path = sam-hq
	url = https://github.com/SysCV/sam-hq.git
	branch = main

# Grounded-SAM - Combined GroundingDINO + SAM pipeline
[submodule "Grounded-Segment-Anything"]
	path = Grounded-Segment-Anything
	url = https://github.com/IDEA-Research/Grounded-Segment-Anything.git
	branch = main

# MobileSAM - Fast lightweight SAM for mobile
# [submodule "MobileSAM"]
#     path = MobileSAM
#     url = https://github.com/ChaoningZhang/MobileSAM.git
#     branch = master

# GenSAM - Generalized SAM for Auto Segmentation
# [submodule "GenSAM"]
#     path = GenSAM
#     url = https://github.com/jbeomlee93/GenSAM.git
#     branch = main

# Personalize-SAM - Personalizing Segment Anything Model with One-Shot
[submodule "PerSAM"]
    path = Personalize-SAM
    url = https://github.com/ZrrSkywalker/Personalize-SAM.git
    branch = main

